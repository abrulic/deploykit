# syntax=docker/dockerfile:1
# Generated by deploykit — safe to edit and commit.
# Build context is the repo ROOT, e.g.:
#   flyctl deploy . --config apps/web/fly.toml --dockerfile apps/web/Dockerfile --app <app>

FROM node:20-slim AS base
ENV PNPM_HOME="/pnpm" PATH="/pnpm:$PATH"
RUN corepack enable || true

# ── prune: isolate web + its workspace deps ──────────────────────────────
FROM base AS prune
WORKDIR /app
COPY . .
RUN pnpm dlx turbo prune @acme/web --docker

# ── install + build ──────────────────────────────────────────────────────────
FROM base AS build
WORKDIR /app
# Lockfile + package manifests first for a cacheable install layer.
COPY --from=prune /app/out/json/ .
RUN pnpm install --frozen-lockfile
# Then the pruned source, and build.
COPY --from=prune /app/out/full/ .
ARG VITE_API_URL
ENV VITE_API_URL=$VITE_API_URL
RUN cd packages/database && DATABASE_URL="postgresql://build:build@localhost:5432/build" pnpm exec prisma generate --schema ./prisma/schema.prisma
RUN pnpm turbo run build --filter=@acme/web

# ── runner ───────────────────────────────────────────────────────────────────
FROM node:20-slim AS runner
WORKDIR /app
ENV NODE_ENV=production
ENV PORT=3000
RUN addgroup --system --gid 1001 nodejs \
 && adduser --system --uid 1001 --ingroup nodejs appuser
EXPOSE 3000

COPY --from=build --chown=appuser:nodejs /app ./
WORKDIR /app/apps/web
USER appuser
CMD ["node","node_modules/@react-router/serve/bin.js","./build/server/index.js"]

